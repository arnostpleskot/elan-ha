{
  "name": "elan-ha",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "bunx prettier --write .",
    "build": "bun build src/index.ts --outdir dist --target bun"
  },
  "dependencies": {
    "elysia": "latest",
    "pino": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pino-pretty": "latest",
    "prettier": "latest",
    "typescript": "latest"
  }
}
